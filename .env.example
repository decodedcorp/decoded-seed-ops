# App
NODE_ENV=development
NEXT_PUBLIC_APP_ENV=development
NEXT_PUBLIC_APP_NAME=decoded-seed-ops

# Vercel / App
APP_BASE_URL=http://localhost:3000

# Warehouse Supabase (server-only)
WAREHOUSE_SUPABASE_URL=https://your-warehouse-project-ref.supabase.co
WAREHOUSE_SUPABASE_SERVICE_ROLE_KEY=your_warehouse_service_role_key
WAREHOUSE_DB_SCHEMA=public

# Storage
WAREHOUSE_STORAGE_BUCKET=images
WAREHOUSE_STORAGE_PREFIX=ops-seed

# Candidate rule
CANDIDATE_START_TS=2025-01-01_00-00-00

# Optional auth / audit
OPS_AUTH_PROVIDER=supabase
OPS_AUDIT_ENABLED=true