# App
NODE_ENV=development
NEXT_PUBLIC_APP_ENV=development
NEXT_PUBLIC_APP_NAME=decoded-seed-ops

# Vercel / App
APP_BASE_URL=http://localhost:3000

# Supabase (server-only)
SUPABASE_URL=https://your-backend-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_backend_service_role_key
SUPABASE_DB_SCHEMA=warehouse
SUPABASE_PROFILE_BUCKET=profile

# Public app DB — Prod 이전 대상 (/post-spots «Prod로 이전», Prod에 이미 있는 post 목록 제외).
# 반드시 실제 Prod 프로젝트로 두세요. 위 SUPABASE_* 와 같은 값이면 Dev=Prod로 보여 전부 숨겨집니다.
# 비우면 Prod 이전/필터는 동작하지 않고 Dev 목록만 표시됩니다.
PROD_PUBLIC_SUPABASE_URL=
PROD_PUBLIC_SUPABASE_SERVICE_ROLE_KEY=

# warehouse 스키마 전체: scripts/pg-dump-warehouse-migration.sh (소스는 DATABASE_URL=Dev DB)

# Cloudflare R2 (server-only)
CLOUDFLARE_R2_ACCOUNT_ID=your_cloudflare_account_id
CLOUDFLARE_R2_ACCESS_KEY_ID=your_r2_access_key_id
CLOUDFLARE_R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
CLOUDFLARE_R2_BUCKET=crawler-media
CLOUDFLARE_R2_PUBLIC_BASE_URL=https://pub-xxxxx.r2.dev
CLOUDFLARE_R2_PREFIX=ops-seed

# Candidate rule
CANDIDATE_START_TS=2025-01-01_00-00-00

# Optional auth / audit
OPS_AUTH_PROVIDER=supabase
OPS_AUDIT_ENABLED=true